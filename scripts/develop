#!/usr/bin/env bash
# Launch a dev Home Assistant instance with this integration loaded.
set -e
cd "$(dirname "$0")/.."

# If a local virtualenv exists, activate it so `hass` is found
# (the VS Code build task runs a fresh shell without it activated).
if [[ -f "${PWD}/.venv/bin/activate" ]]; then
    # shellcheck disable=SC1091
    source "${PWD}/.venv/bin/activate"
fi

# Clear message if Home Assistant isn't installed yet.
if ! command -v hass >/dev/null 2>&1; then
    echo "Home Assistant ('hass') not found."
    echo "Install it first:"
    echo "  python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt"
    exit 1
fi

CONFIG_DIR="${PWD}/config"
mkdir -p "${CONFIG_DIR}"

# First run: write a minimal dev config. We do NOT use `default_config` because
# it pulls in go2rtc, which needs a binary not present in a bare venv/Core
# install; it fails to set up and takes the config/UI panel down with it.
# Add components below as you need them.
if [[ ! -f "${CONFIG_DIR}/configuration.yaml" ]]; then
    touch "${CONFIG_DIR}/automations.yaml" \
          "${CONFIG_DIR}/scripts.yaml" \
          "${CONFIG_DIR}/scenes.yaml"
    cat > "${CONFIG_DIR}/configuration.yaml" <<'YAML'
# Minimal dev config for the Medication Reminder integration.
# Avoids default_config (it pulls in go2rtc, which needs a binary not present
# in a bare venv/Core install). Add components here as you need them.
frontend:
config:
mobile_app:

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml

logger:
  default: info
  logs:
    custom_components.medication_reminder: debug
YAML
fi

# Make this integration visible to HA via custom_components.
mkdir -p "${CONFIG_DIR}/custom_components"
ln -sfn "${PWD}/custom_components/medication_reminder" \
       "${CONFIG_DIR}/custom_components/medication_reminder"

# Run Home Assistant (Ctrl+C to stop).
hass --config "${CONFIG_DIR}" --debug
